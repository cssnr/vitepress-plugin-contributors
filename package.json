{
  "name": "@cssnr/vitepress-plugin-contributors",
  "version": "0.0.1",
  "description": "VitePress Plugin to easily generate, update and display GitHub contributors. Automatically updated on every installation or deployment with custom options.",
  "keywords": [
    "vitepress-plugin",
    "vitepress",
    "plugin",
    "contributors",
    "github"
  ],
  "homepage": "https://github.com/cssnr/vitepress-plugin-contributors",
  "bugs": {
    "url": "https://github.com/cssnr/vitepress-plugin-contributors/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cssnr/vitepress-plugin-contributors.git"
  },
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/cssnr"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Shane",
    "url": "https://cssnr.github.io/"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/Contributors.es.js",
      "require": "./dist/Contributors.umd.js",
      "types": "./dist/Contributors.vue.d.ts"
    },
    "./style.css": "./dist/Contributors.css"
  },
  "main": "dist/Contributors.umd.js",
  "module": "dist/Contributors.es.js",
  "types": "dist/Contributors.vue.d.ts",
  "bin": {
    "get-contributors": "dist/get-contributors.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "contributors": "tsdown",
    "contributors:build": "npx ncc build -m src/get-contributors.ts -o dist/get-contributors",
    "contributors:watch": "tsdown --watch",
    "docs": "npm run docs:dev",
    "docs:build": "vitepress build docs",
    "docs:deploy": "npm run get-contributors && npm run docs:build",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "get-contributors": "npx get-contributors vuejs/vitepress -m 98 -f docs/.vitepress/contributors.json",
    "prepare": "npm run build && npm run contributors",
    "prettier:check": "npx prettier --check .",
    "prettier:write": "npx prettier --write ."
  },
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@cssnr/vitepress-plugin-copybutton": "^0.0.2",
    "@types/node": "^25.6.0",
    "@vercel/ncc": "^0.38.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.7"
  }
}
